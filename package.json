{
  "name": "uts",
  "version": "0.0.0",
  "description": "Unix timestamp conversion CLI",
  "type": "module",
  "bin": {
    "uts": "./dist/uts"
  },
  "scripts": {
    "clean": "rimraf ./dist",
    "dev": "tsx src/uts.ts",
    "compile": "node ./scripts/build.mjs",
    "link": "chmod +x dist/uts",
    "build": "run-s lint clean compile link",
    "lint": "run-s lint:format lint:ts lint:tsc",
    "lint:ts": "eslint .",
    "lint:tsc": "tsc -p tsconfig.json",
    "lint:format": "prettier -c ./src ./scripts ./README.md ./BUILD.md",
    "lint:formatfix": "prettier -w ./src ./scripts ./README.md ./BUILD.md"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "20.19.39",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "esbuild": "0.28.0",
    "eslint": "10.2.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1"
  }
}
